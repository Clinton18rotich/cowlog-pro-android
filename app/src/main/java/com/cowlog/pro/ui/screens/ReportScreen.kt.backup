package com.cowlog.pro.ui.screens

import android.content.Context
import android.content.Intent
import android.graphics.*
import android.graphics.pdf.PdfDocument
import android.os.Build
import android.os.Environment
import android.print.PrintAttributes
import android.print.PrintDocumentAdapter
import android.print.PrintManager
import android.widget.Toast
import androidx.compose.foundation.background
import androidx.compose.foundation.layout.*
import androidx.compose.foundation.rememberScrollState
import androidx.compose.foundation.text.BasicTextField
import androidx.compose.foundation.verticalScroll
import androidx.compose.material3.*
import androidx.compose.runtime.*
import androidx.compose.ui.Alignment
import androidx.compose.ui.Modifier
import androidx.compose.ui.graphics.Color
import androidx.compose.ui.platform.LocalContext
import androidx.compose.ui.text.TextStyle
import androidx.compose.ui.text.font.FontWeight
import androidx.compose.ui.text.style.TextAlign
import androidx.compose.ui.unit.dp
import androidx.compose.ui.unit.sp
import androidx.core.content.FileProvider
import androidx.navigation.NavController
import com.cowlog.pro.data.*
import com.cowlog.pro.ui.BottomNavBar
import com.cowlog.pro.ui.TopBar
import java.io.File
import java.io.FileOutputStream
import java.text.SimpleDateFormat
import java.util.*

@Composable
fun ReportScreen(
    appData: AppData,
    settings: ProjectSettings,
    navController: NavController,
    onUpdate: (AppData) -> Unit
) {
    val context = LocalContext.current
    val dateFormat = remember { SimpleDateFormat("yyyy-MM-dd", Locale.getDefault()) }
    val today = remember { dateFormat.format(Date()) }
    val timeFormat = remember { SimpleDateFormat("HH:mm", Locale.getDefault()) }
    val rdate = remember { SimpleDateFormat("EEEE, dd MMMM yyyy", Locale.getDefault()).format(Date()) }

    val diaryEntries = appData.diary.filter { dateFormat.format(Date(it.timestamp)) == today }
    val inspections = appData.inspections.filter { dateFormat.format(Date(it.timestamp)) == today }
    val openNcrs = appData.ncrs.filter { it.status == "open" }
    val siteInstructions = appData.instructions.filter { dateFormat.format(Date(it.timestamp)) == today }
    val attendance = appData.attendance.filter { it.date == today }
    val lowStock = appData.materials.filter { it.currentStock <= it.minStock && it.minStock > 0 }
    val deliveries = appData.materialLogs.filter { it.date == today && it.type == "delivery" }
    val activePlant = appData.plantEquipment.filter { it.status != "Demobilized" }

    val passRate = if (inspections.isNotEmpty()) (inspections.count { it.result == "pass" } * 100 / inspections.size) else 100
    val totalWorkers = attendance.sumOf { (it.count.toIntOrNull() ?: 0) }
    val reportNumber = "COW/${settings.reportCounter}/${Calendar.getInstance().get(Calendar.YEAR)}"

    var edCow by remember { mutableStateOf(settings.cowName) }
    var edRemarks by remember { mutableStateOf("Work is progressing in accordance with the approved programme and specifications unless otherwise noted. Contractor is reminded to maintain quality standards and adhere to all safety requirements.") }
    var edHnS by remember { mutableStateOf("No specific H&S issues noted. Site appeared orderly. All personnel observed wearing mandatory PPE.") }
    var edWeather by remember { mutableStateOf("☀️ Sunny & Clear") }
    var edTemp by remember { mutableStateOf("26°C") }
    var edContractorRep by remember { mutableStateOf("") }

    val shareText = buildString {
        append("CLERK OF WORKS — DAILY SITE REPORT\n")
        append("══════════════════════════════\n\n")
        append("Report: $reportNumber\n")
        append("Date: $rdate\n")
        append("Project: ${settings.projectName}\n")
        append("Contractor: ${settings.contractorName}\n")
        append("Reported by: $edCow\n\n")
        append("Activities: ${diaryEntries.size}\n")
        append("Inspections: ${inspections.size} (Pass rate: ${passRate}%)\n")
        append("Open NCRs: ${openNcrs.size}\n")
        append("Workers: $totalWorkers\n")
        append("Plant: ${activePlant.size} items\n")
        append("Materials delivered: ${deliveries.size} items\n\n")
        append("Remarks: $edRemarks\n\n")
        append("— CoW Log Pro")
    }

    Scaffold(
        topBar = { TopBar("📄 Daily Report", navController) },
        bottomBar = { BottomNavBar(navController, "report") }
    ) { padding ->
        Column(
            modifier = Modifier
                .fillMaxSize()
                .padding(padding)
                .verticalScroll(rememberScrollState())
        ) {
            Row(
                modifier = Modifier.fillMaxWidth().padding(8.dp),
                horizontalArrangement = Arrangement.spacedBy(4.dp)
            ) {
                Button(
                    onClick = {
                        val file = generateReportPDF(context, appData, settings, edCow, edRemarks, edHnS, edWeather, edTemp, edContractorRep)
                        Toast.makeText(context, "PDF saved: ${file.absolutePath}", Toast.LENGTH_LONG).show()
                    },
                    modifier = Modifier.weight(1f),
                    colors = ButtonDefaults.buttonColors(containerColor = Color(0xFF0A84FF))
                ) { Text("📄 PDF", fontSize = 9.sp) }

                Button(
                    onClick = {
                        try {
                            val file = generateReportPDF(context, appData, settings, edCow, edRemarks, edHnS, edWeather, edTemp, edContractorRep)
                            printPDF(context, file)
                        } catch (e: Exception) {
                            Toast.makeText(context, "Print error: ${e.message}", Toast.LENGTH_SHORT).show()
                        }
                    },
                    modifier = Modifier.weight(1f),
                    colors = ButtonDefaults.buttonColors(containerColor = Color(0xFF6C5CE7))
                ) { Text("🖨️ Print", fontSize = 9.sp) }

                Button(
                    onClick = {
                        try {
                            val file = generateReportPDF(context, appData, settings, edCow, edRemarks, edHnS, edWeather, edTemp, edContractorRep)
                            val uri = FileProvider.getUriForFile(context, "${context.packageName}.fileprovider", file)
                            val intent = Intent(Intent.ACTION_SEND).apply {
                                type = "application/pdf"
                                putExtra(Intent.EXTRA_STREAM, uri)
                                putExtra(Intent.EXTRA_TEXT, shareText)
                                setPackage("com.whatsapp")
                                addFlags(Intent.FLAG_GRANT_READ_URI_PERMISSION)
                            }
                            context.startActivity(intent)
                        } catch (e: Exception) {
                            val intent = Intent(Intent.ACTION_SEND).apply {
                                type = "text/plain"
                                putExtra(Intent.EXTRA_TEXT, shareText)
                            }
                            context.startActivity(Intent.createChooser(intent, "Share Report"))
                        }
                    },
                    modifier = Modifier.weight(1f),
                    colors = ButtonDefaults.buttonColors(containerColor = Color(0xFF25D366))
                ) { Text("📱 WhatsApp", fontSize = 9.sp) }

                Button(
                    onClick = {
                        try {
                            val file = generateReportPDF(context, appData, settings, edCow, edRemarks, edHnS, edWeather, edTemp, edContractorRep)
                            val uri = FileProvider.getUriForFile(context, "${context.packageName}.fileprovider", file)
                            val intent = Intent(Intent.ACTION_SEND).apply {
                                type = "application/pdf"
                                putExtra(Intent.EXTRA_STREAM, uri)
                                putExtra(Intent.EXTRA_SUBJECT, "CoW Daily Report — $rdate")
                                putExtra(Intent.EXTRA_TEXT, shareText)
                                addFlags(Intent.FLAG_GRANT_READ_URI_PERMISSION)
                            }
                            context.startActivity(Intent.createChooser(intent, "Send Email"))
                        } catch (e: Exception) {
                            val intent = Intent(Intent.ACTION_SENDTO).apply {
                                data = android.net.Uri.parse("mailto:")
                                putExtra(Intent.EXTRA_SUBJECT, "CoW Daily Report — $rdate")
                                putExtra(Intent.EXTRA_TEXT, shareText)
                            }
                            context.startActivity(intent)
                        }
                    },
                    modifier = Modifier.weight(1f),
                    colors = ButtonDefaults.buttonColors(containerColor = Color(0xFF2C2C2E))
                ) { Text("📧 Email", fontSize = 9.sp) }

                Button(
                    onClick = { onUpdate(appData) },
                    modifier = Modifier.weight(1f),
                    colors = ButtonDefaults.buttonColors(containerColor = Color(0xFF2C2C2E))
                ) { Text("🔄 Refresh", fontSize = 9.sp) }
            }

            Row(
                modifier = Modifier.fillMaxWidth().padding(horizontal = 8.dp),
                horizontalArrangement = Arrangement.spacedBy(4.dp)
            ) {
                StatPill("${diaryEntries.size}", "Activities", Color(0xFF0A84FF))
                StatPill("${passRate}%", "Pass Rate", if (passRate >= 80) Color(0xFF30D158) else Color(0xFFFF9F0A))
                StatPill("${openNcrs.size}", "NCRs", if (openNcrs.isEmpty()) Color(0xFF30D158) else Color(0xFFFF453A))
                StatPill("$totalWorkers", "Workers", Color(0xFF30D158))
            }

            Spacer(modifier = Modifier.height(8.dp))

            Surface(
                modifier = Modifier.fillMaxWidth().padding(4.dp),
                color = Color.White,
                shape = MaterialTheme.shapes.medium,
                shadowElevation = 8.dp
            ) {
                Column(modifier = Modifier.padding(12.dp)) {
                    Surface(modifier = Modifier.fillMaxWidth(), color = Color(0xFF1A1A2E)) {
                        Column(modifier = Modifier.padding(14.dp), horizontalAlignment = Alignment.CenterHorizontally) {
                            Text("CLERK OF WORKS — DAILY SITE REPORT", fontSize = 12.sp, fontWeight = FontWeight.Bold, color = Color(0xFFF78166), letterSpacing = 1.sp, textAlign = TextAlign.Center)
                            Text(settings.projectName.ifEmpty { "Project" }, fontSize = 7.sp, color = Color(0xFFA0A0B8), textAlign = TextAlign.Center)
                            Text("Republic of Kenya — Ministry of Public Works", fontSize = 6.sp, color = Color(0xFF636366))
                        }
                    }

                    Surface(modifier = Modifier.fillMaxWidth(), color = Color(0xFFF8F9FA)) {
                        Column(modifier = Modifier.padding(8.dp)) {
                            ReportMetaRow("REPORT NO:", reportNumber, "DATE:", rdate)
                            ReportMetaRow("PROJECT:", settings.projectName, "CONTRACT NO:", settings.contractNo)
                            ReportMetaRow("CONTRACTOR:", settings.contractorName, "REPORTED BY:", edCow)
                            ReportMetaRow("WEATHER:", edWeather, "TEMP:", edTemp)
                        }
                    }

                    Spacer(modifier = Modifier.height(6.dp))

                    ReportSection("1. WORK PROGRESS & OBSERVATIONS")
                    if (diaryEntries.isNotEmpty()) {
                        diaryEntries.forEachIndexed { i, entry ->
                            Text("1.${i+1} ${entry.title}${if (entry.percentComplete.isNotEmpty()) " [${entry.percentComplete}%]" else ""}", fontSize = 7.sp, fontWeight = FontWeight.Bold, color = Color.Black)
                            Text("    📍 ${entry.location} | 🕐 ${timeFormat.format(Date(entry.timestamp))}", fontSize = 6.sp, color = Color.DarkGray)
                            Text("    ${entry.description.take(200)}", fontSize = 6.sp, color = Color.Black)
                        }
                    } else {
                        Text("    No diary entries recorded for today.", fontSize = 6.sp, color = Color.DarkGray)
                    }

                    ReportSection("2. INSPECTIONS & TESTS")
                    if (inspections.isNotEmpty()) {
                        Text("    Pass Rate: ${passRate}% (${inspections.count { it.result == "pass" }}/${inspections.size})", fontSize = 7.sp, fontWeight = FontWeight.Bold, color = Color.Black)
                        inspections.forEach { insp ->
                            Text("    ${insp.checklistType} — ${insp.result.uppercase()}", fontSize = 6.sp, fontWeight = FontWeight.Bold, color = if (insp.result == "pass") Color(0xFF008800) else Color.Red)
                            Text("    📍 ${insp.location} | ✅ ${insp.items.count { it.passed }}/${insp.items.size} passed", fontSize = 6.sp, color = Color.DarkGray)
                        }
                    } else {
                        Text("    No inspections recorded for today.", fontSize = 6.sp, color = Color.DarkGray)
                    }

                    ReportSection("3. NON-CONFORMANCE REPORTS (NCRs)")
                    if (openNcrs.isNotEmpty()) {
                        Text("    Outstanding NCRs: ${openNcrs.size}", fontSize = 7.sp, fontWeight = FontWeight.Bold, color = Color.Red)
                        openNcrs.take(5).forEach { ncr ->
                            Text("    • NCR-${ncr.id.take(6)}: ${ncr.title} [${ncr.severity}] — ${ncr.location}", fontSize = 6.sp, color = Color.Black)
                        }
                        if (openNcrs.size > 5) {
                            Text("    ... and ${openNcrs.size - 5} more", fontSize = 6.sp, color = Color.DarkGray)
                        }
                    } else {
                        Text("    No outstanding NCRs.", fontSize = 6.sp, color = Color.DarkGray)
                    }

                    ReportSection("4. SITE INSTRUCTIONS")
                    if (siteInstructions.isNotEmpty()) {
                        siteInstructions.take(3).forEach { si ->
                            Text("    SI-${si.id.take(6)}: ${si.description.take(80)} (To: ${si.issuedTo})", fontSize = 6.sp, color = Color.Black)
                        }
                        if (siteInstructions.size > 3) {
                            Text("    ... and ${siteInstructions.size - 3} more", fontSize = 6.sp, color = Color.DarkGray)
                        }
                    } else {
                        Text("    No site instructions issued today.", fontSize = 6.sp, color = Color.DarkGray)
                    }

                    ReportSection("5. PLANT & EQUIPMENT ON SITE")
                    if (activePlant.isNotEmpty()) {
                        activePlant.take(5).forEach { p ->
                            Text("    ${p.name} — ${p.status}", fontSize = 6.sp, color = Color.Black)
                        }
                        if (activePlant.size > 5) {
                            Text("    ... and ${activePlant.size - 5} more items", fontSize = 6.sp, color = Color.DarkGray)
                        }
                    } else {
                        Text("    No plant equipment recorded on site.", fontSize = 6.sp, color = Color.DarkGray)
                    }

                    ReportSection("6. LABOUR ON SITE")
                    if (totalWorkers > 0) {
                        Text("    Total Personnel: $totalWorkers", fontSize = 7.sp, fontWeight = FontWeight.Bold, color = Color.Black)
                        val breakdown = attendance.groupBy { it.category }
                            .mapValues { it.value.sumOf { v -> v.count.toIntOrNull() ?: 0 } }
                        breakdown.forEach { (cat, count) ->
                            Text("    $cat: $count", fontSize = 6.sp, color = Color.Black)
                        }
                    } else {
                        Text("    No labour data recorded for today.", fontSize = 6.sp, color = Color.DarkGray)
                    }

                    ReportSection("7. MATERIALS DELIVERED / STOCK")
                    if (deliveries.isNotEmpty()) {
                        deliveries.take(4).forEach { log ->
                            val mat = appData.materials.find { it.id == log.materialId }
                            Text("    ${mat?.name ?: "Material"}: ${log.quantity} ${log.unit}", fontSize = 6.sp, color = Color.Black)
                        }
                        if (deliveries.size > 4) {
                            Text("    ... and ${deliveries.size - 4} more deliveries", fontSize = 6.sp, color = Color.DarkGray)
                        }
                    } else {
                        Text("    No material deliveries recorded today.", fontSize = 6.sp, color = Color.DarkGray)
                    }
                    if (lowStock.isNotEmpty()) {
                        Text("    ⚠️ LOW STOCK ALERT:", fontSize = 6.sp, fontWeight = FontWeight.Bold, color = Color.Red)
                        lowStock.forEach { m ->
                            Text("    • ${m.name}: ${m.currentStock} ${m.unit} (min: ${m.minStock})", fontSize = 6.sp, color = Color.Red)
                        }
                    }

                    ReportSection("8. HEALTH & SAFETY OBSERVATIONS")
                    BasicTextField(
                        value = edHnS,
                        onValueChange = { edHnS = it },
                        textStyle = TextStyle(fontSize = 6.sp, color = Color.Black),
                        modifier = Modifier.fillMaxWidth().background(Color(0xFFFFFDE7)).padding(4.dp),
                        minLines = 2
                    )

                    ReportSection("9. GENERAL REMARKS")
                    BasicTextField(
                        value = edRemarks,
                        onValueChange = { edRemarks = it },
                        textStyle = TextStyle(fontSize = 6.sp, color = Color.Black),
                        modifier = Modifier.fillMaxWidth().background(Color(0xFFFFFDE7)).padding(4.dp),
                        minLines = 3
                    )

                    Spacer(modifier = Modifier.height(12.dp))
                    Divider(color = Color(0xFFE0E0E0), thickness = 2.dp)
                    Text("REPORT END — $rdate", fontSize = 7.sp, fontWeight = FontWeight.Bold, color = Color.Black, textAlign = TextAlign.Center, modifier = Modifier.fillMaxWidth().padding(vertical = 4.dp))
                    Row(modifier = Modifier.fillMaxWidth(), horizontalArrangement = Arrangement.SpaceEvenly) {
                        Column(horizontalAlignment = Alignment.CenterHorizontally, modifier = Modifier.weight(1f)) {
                            Divider(color = Color(0xFF1A1A1A), modifier = Modifier.fillMaxWidth().padding(horizontal = 8.dp))
                            BasicTextField(value = edCow, onValueChange = { edCow = it }, textStyle = TextStyle(fontSize = 8.sp, fontWeight = FontWeight.Bold, color = Color(0xFF1A1A1A), textAlign = TextAlign.Center), modifier = Modifier.fillMaxWidth().background(Color(0xFFFFFDE7)).padding(2.dp), singleLine = true)
                            Text("Clerk of Works", fontSize = 6.sp, color = Color(0xFF888888))
                            Text("Date: ................", fontSize = 5.sp, color = Color(0xFF888888))
                        }
                        Column(horizontalAlignment = Alignment.CenterHorizontally, modifier = Modifier.weight(1f)) {
                            Divider(color = Color(0xFF1A1A1A), modifier = Modifier.fillMaxWidth().padding(horizontal = 8.dp))
                            BasicTextField(value = edContractorRep, onValueChange = { edContractorRep = it }, textStyle = TextStyle(fontSize = 8.sp, fontWeight = FontWeight.Bold, color = Color(0xFF1A1A1A), textAlign = TextAlign.Center), modifier = Modifier.fillMaxWidth().background(Color(0xFFFFFDE7)).padding(2.dp), singleLine = true)
                            Text("Contractor's Representative", fontSize = 6.sp, color = Color(0xFF888888))
                            Text("Date: ................", fontSize = 5.sp, color = Color(0xFF888888))
                        }
                    }
                }
            }
        }
    }
}
@Composable
fun StatPill(value: String, label: String, color: Color) {
    Surface(
        modifier = Modifier.weight(1f),
        color = Color(0xFF1C1C1E),
        shape = MaterialTheme.shapes.small
    ) {
        Column(modifier = Modifier.padding(6.dp), horizontalAlignment = Alignment.CenterHorizontally) {
            Text(value, fontSize = 16.sp, fontWeight = FontWeight.Bold, color = color)
            Text(label, fontSize = 7.sp, color = Color.Gray)
        }
    }
}

@Composable
fun ReportMetaRow(l1: String, v1: String, l2: String, v2: String) {
    Row(modifier = Modifier.fillMaxWidth().padding(vertical = 1.dp)) {
        Row(modifier = Modifier.weight(1f)) {
            Text("$l1 ", fontSize = 6.sp, fontWeight = FontWeight.Bold, color = Color(0xFF555555))
            Text(v1.ifEmpty { "___________" }, fontSize = 6.sp, color = Color.Black)
        }
        Row(modifier = Modifier.weight(1f)) {
            Text("$l2 ", fontSize = 6.sp, fontWeight = FontWeight.Bold, color = Color(0xFF555555))
            Text(v2.ifEmpty { "___________" }, fontSize = 6.sp, color = Color.Black)
        }
    }
}

@Composable
fun ReportSection(title: String) {
    Spacer(modifier = Modifier.height(6.dp))
    Surface(modifier = Modifier.fillMaxWidth(), color = Color(0xFFE8E8E8)) {
        Text(title, fontSize = 7.sp, fontWeight = FontWeight.Bold, color = Color.Black, modifier = Modifier.padding(horizontal = 8.dp, vertical = 4.dp), letterSpacing = 0.5.sp)
    }
    Divider(color = Color.Black, thickness = 0.5.dp)
}
fun generateReportPDF(
    context: Context,
    appData: AppData,
    settings: ProjectSettings,
    cow: String,
    remarks: String,
    hns: String,
    weather: String,
    temp: String,
    contractorRep: String
): File {
    val pdf = PdfDocument()
    val pageInfo = PdfDocument.PageInfo.Builder(595, 842, 1).create()
    val page = pdf.startPage(pageInfo)
    val canvas = page.canvas

    val dateFormat = SimpleDateFormat("yyyy-MM-dd", Locale.getDefault())
    val today = dateFormat.format(Date())
    val diaryEntries = appData.diary.filter { dateFormat.format(Date(it.timestamp)) == today }
    val inspections = appData.inspections.filter { dateFormat.format(Date(it.timestamp)) == today }
    val openNcrs = appData.ncrs.filter { it.status == "open" }
    val siteInstructions = appData.instructions.filter { dateFormat.format(Date(it.timestamp)) == today }
    val attendance = appData.attendance.filter { it.date == today }
    val lowStock = appData.materials.filter { it.currentStock <= it.minStock && it.minStock > 0 }
    val deliveries = appData.materialLogs.filter { it.date == today && it.type == "delivery" }
    val activePlant = appData.plantEquipment.filter { it.status != "Demobilized" }

    val passRate = if (inspections.isNotEmpty()) (inspections.count { it.result == "pass" } * 100 / inspections.size) else 100
    val totalWorkers = attendance.sumOf { (it.count.toIntOrNull() ?: 0) }
    val reportNumber = "COW/${settings.reportCounter}/${Calendar.getInstance().get(Calendar.YEAR)}"
    val rdate = SimpleDateFormat("EEEE, dd MMMM yyyy", Locale.getDefault()).format(Date())
    val timeFormat = SimpleDateFormat("HH:mm", Locale.getDefault())

    val headerBg = Paint().apply { color = android.graphics.Color.parseColor("#1A1A2E") }
    val titlePaint = Paint().apply {
        textSize = 14f
        typeface = Typeface.create(Typeface.SERIF, Typeface.BOLD)
        textAlign = Paint.Align.CENTER
        color = android.graphics.Color.parseColor("#F78166")
    }
    val subTitlePaint = Paint().apply {
        textSize = 8f
        typeface = Typeface.create(Typeface.SERIF, Typeface.BOLD)
        color = android.graphics.Color.parseColor("#A0A0B8")
    }
    val subSmallPaint = Paint().apply {
        textSize = 7f
        typeface = Typeface.create(Typeface.SERIF, Typeface.NORMAL)
        color = android.graphics.Color.parseColor("#636366")
    }
    val metaLabel = Paint().apply {
        textSize = 7f
        typeface = Typeface.create(Typeface.SERIF, Typeface.BOLD)
        color = android.graphics.Color.parseColor("#555555")
    }
    val metaValue = Paint().apply {
        textSize = 7f
        typeface = Typeface.create(Typeface.SERIF, Typeface.NORMAL)
        color = android.graphics.Color.BLACK
    }
    val sectionLabel = Paint().apply {
        textSize = 8f
        typeface = Typeface.create(Typeface.SERIF, Typeface.BOLD)
        color = android.graphics.Color.BLACK
    }
    val bodyText = Paint().apply {
        textSize = 6.5f
        typeface = Typeface.create(Typeface.SERIF, Typeface.NORMAL)
        color = android.graphics.Color.BLACK
    }
    val bodyBold = Paint().apply {
        textSize = 6.5f
        typeface = Typeface.create(Typeface.SERIF, Typeface.BOLD)
        color = android.graphics.Color.BLACK
    }
    val bodyRed = Paint().apply {
        textSize = 6.5f
        typeface = Typeface.create(Typeface.SERIF, Typeface.BOLD)
        color = android.graphics.Color.RED
    }
    val sigPaint = Paint().apply {
        textSize = 8f
        typeface = Typeface.create(Typeface.SERIF, Typeface.BOLD)
        color = android.graphics.Color.BLACK
    }

    var y = 20f

    canvas.drawRect(0f, 0f, 595f, 50f, headerBg)
    canvas.drawText("CLERK OF WORKS — DAILY SITE REPORT", 297f, 22f, titlePaint)
    y = 34f
    canvas.drawText(settings.projectName.ifEmpty { "Project" }, 297f, y, subTitlePaint)
    y = 44f
    canvas.drawText("Republic of Kenya — Ministry of Public Works", 297f, y, subSmallPaint)
    y = 58f

    fun drawMeta(label1: String, value1: String, label2: String, value2: String) {
        canvas.drawText("$label1 ", 40f, y, metaLabel)
        canvas.drawText(value1.ifEmpty { "___________" }, 40f + 65f, y, metaValue)
        canvas.drawText("$label2 ", 320f, y, metaLabel)
        canvas.drawText(value2.ifEmpty { "___________" }, 320f + 65f, y, metaValue)
        y += 12f
    }
    drawMeta("REPORT NO:", reportNumber, "DATE:", rdate)
    drawMeta("PROJECT:", settings.projectName, "CONTRACT NO:", settings.contractNo)
    drawMeta("CONTRACTOR:", settings.contractorName, "REPORTED BY:", cow)
    drawMeta("WEATHER:", weather, "TEMP:", temp)
    y += 6f

    canvas.drawText("1. WORK PROGRESS & OBSERVATIONS", 40f, y, sectionLabel)
    y += 10f
    if (diaryEntries.isNotEmpty()) {
        diaryEntries.take(8).forEachIndexed { i, entry ->
            val line = "1.${i+1} ${entry.title}${if (entry.percentComplete.isNotEmpty()) " [${entry.percentComplete}%]" else ""}"
            canvas.drawText(line, 45f, y, bodyBold)
            y += 9f
            canvas.drawText("    📍 ${entry.location} | ${timeFormat.format(Date(entry.timestamp))}", 45f, y, bodyText)
            y += 9f
            canvas.drawText("    ${entry.description.take(150)}", 45f, y, bodyText)
            y += 9f
        }
        if (diaryEntries.size > 8) {
            canvas.drawText("    ... and ${diaryEntries.size - 8} more activities", 45f, y, bodyText)
            y += 9f
        }
    } else {
        canvas.drawText("    No diary entries recorded for today.", 45f, y, bodyText)
        y += 9f
    }
    y += 4f

    canvas.drawText("2. INSPECTIONS & TESTS", 40f, y, sectionLabel)
    y += 10f
    if (inspections.isNotEmpty()) {
        canvas.drawText("    Pass Rate: ${passRate}% (${inspections.count { it.result == "pass" }}/${inspections.size})", 45f, y, bodyBold)
        y += 9f
        inspections.take(5).forEach { insp ->
            val status = insp.result.uppercase()
            val paint = if (insp.result == "pass") bodyBold else bodyRed
            canvas.drawText("    ${insp.checklistType} — $status", 45f, y, paint)
            y += 9f
            canvas.drawText("    📍 ${insp.location} | ✅ ${insp.items.count { it.passed }}/${insp.items.size} passed", 45f, y, bodyText)
            y += 9f
        }
        if (inspections.size > 5) {
            canvas.drawText("    ... and ${inspections.size - 5} more inspections", 45f, y, bodyText)
            y += 9f
        }
    } else {
        canvas.drawText("    No inspections recorded for today.", 45f, y, bodyText)
        y += 9f
    }
    y += 4f

    canvas.drawText("3. NON-CONFORMANCE REPORTS (NCRs)", 40f, y, sectionLabel)
    y += 10f
    if (openNcrs.isNotEmpty()) {
        canvas.drawText("    Outstanding NCRs: ${openNcrs.size}", 45f, y, bodyRed)
        y += 9f
        openNcrs.take(5).forEach { ncr ->
            canvas.drawText("    • NCR-${ncr.id.take(6)}: ${ncr.title} [${ncr.severity}] — ${ncr.location}", 45f, y, bodyText)
            y += 9f
        }
        if (openNcrs.size > 5) {
            canvas.drawText("    ... and ${openNcrs.size - 5} more", 45f, y, bodyText)
            y += 9f
        }
    } else {
        canvas.drawText("    No outstanding NCRs.", 45f, y, bodyText)
        y += 9f
    }
    y += 4f

    canvas.drawText("4. SITE INSTRUCTIONS", 40f, y, sectionLabel)
    y += 10f
    if (siteInstructions.isNotEmpty()) {
        siteInstructions.take(3).forEach { si ->
            canvas.drawText("    SI-${si.id.take(6)}: ${si.description.take(80)} (To: ${si.issuedTo})", 45f, y, bodyText)
            y += 9f
        }
        if (siteInstructions.size > 3) {
            canvas.drawText("    ... and ${siteInstructions.size - 3} more instructions", 45f, y, bodyText)
            y += 9f
        }
    } else {
        canvas.drawText("    No site instructions issued today.", 45f, y, bodyText)
        y += 9f
    }
    y += 4f

    canvas.drawText("5. PLANT & EQUIPMENT ON SITE", 40f, y, sectionLabel)
    y += 10f
    if (activePlant.isNotEmpty()) {
        activePlant.take(5).forEach { p ->
            canvas.drawText("    ${p.name} — ${p.status}", 45f, y, bodyText)
            y += 9f
        }
        if (activePlant.size > 5) {
            canvas.drawText("    ... and ${activePlant.size - 5} more items", 45f, y, bodyText)
            y += 9f
        }
    } else {
        canvas.drawText("    No plant equipment recorded on site.", 45f, y, bodyText)
        y += 9f
    }
    y += 4f

    canvas.drawText("6. LABOUR ON SITE", 40f, y, sectionLabel)
    y += 10f
    if (totalWorkers > 0) {
        canvas.drawText("    Total Personnel: $totalWorkers", 45f, y, bodyBold)
        y += 9f
        val breakdown = attendance.groupBy { it.category }
            .mapValues { it.value.sumOf { v -> v.count.toIntOrNull() ?: 0 } }
        breakdown.forEach { (cat, count) ->
            canvas.drawText("    $cat: $count", 45f, y, bodyText)
            y += 9f
        }
    } else {
        canvas.drawText("    No labour data recorded for today.", 45f, y, bodyText)
        y += 9f
    }
    y += 4f

    canvas.drawText("7. MATERIALS DELIVERED / STOCK", 40f, y, sectionLabel)
    y += 10f
    if (deliveries.isNotEmpty()) {
        deliveries.take(4).forEach { log ->
            val mat = appData.materials.find { it.id == log.materialId }
            canvas.drawText("    ${mat?.name ?: "Material"}: ${log.quantity} ${log.unit}", 45f, y, bodyText)
            y += 9f
        }
        if (deliveries.size > 4) {
            canvas.drawText("    ... and ${deliveries.size - 4} more deliveries", 45f, y, bodyText)
            y += 9f
        }
    } else {
        canvas.drawText("    No material deliveries recorded today.", 45f, y, bodyText)
        y += 9f
    }
    if (lowStock.isNotEmpty()) {
        canvas.drawText("    ⚠️ LOW STOCK ALERT:", 45f, y, bodyRed)
        y += 9f
        lowStock.forEach { m ->
            canvas.drawText("    • ${m.name}: ${m.currentStock} ${m.unit} (min: ${m.minStock})", 45f, y, bodyRed)
            y += 9f
        }
    }
    y += 4f

    canvas.drawText("8. HEALTH & SAFETY OBSERVATIONS", 40f, y, sectionLabel)
    y += 10f
    hns.split("\n").forEach { line ->
        canvas.drawText("    $line", 45f, y, bodyText)
        y += 9f
    }
    y += 4f

    canvas.drawText("9. GENERAL REMARKS", 40f, y, sectionLabel)
    y += 10f
    remarks.split("\n").forEach { line ->
        canvas.drawText("    $line", 45f, y, bodyText)
        y += 9f
    }
    y += 12f

    canvas.drawText("REPORT END — $rdate", 297f, y, sectionLabel)
    y += 16f
    canvas.drawText("SIGNED: ______________________________", 80f, y, bodyText)
    canvas.drawText(cow.ifEmpty { "Clerk of Works" }, 80f, y + 14f, sigPaint)
    canvas.drawText("Clerk of Works", 80f, y + 22f, bodyText)
    canvas.drawText("Date: ................", 80f, y + 30f, bodyText)

    canvas.drawText("SIGNED: ______________________________", 320f, y, bodyText)
    canvas.drawText(contractorRep.ifEmpty { "Contractor's Rep" }, 320f, y + 14f, sigPaint)
    canvas.drawText("Contractor's Representative", 320f, y + 22f, bodyText)
    canvas.drawText("Date: ................", 320f, y + 30f, bodyText)

    pdf.finishPage(page)

    val fileName = "CoW-Report-${SimpleDateFormat("yyyyMMdd", Locale.getDefault()).format(Date())}.pdf"
    val downloadsDir = if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.Q) {
        context.getExternalFilesDir(Environment.DIRECTORY_DOWNLOADS) ?: context.filesDir
    } else {
        Environment.getExternalStoragePublicDirectory(Environment.DIRECTORY_DOWNLOADS)
    }
    val file = File(downloadsDir, fileName)
    try {
        pdf.writeTo(FileOutputStream(file))
    } catch (e: Exception) {
        e.printStackTrace()
    } finally {
        pdf.close()
    }
    return file
}

fun printPDF(context: Context, pdfFile: File) {
    try {
        val printManager = context.getSystemService(Context.PRINT_SERVICE) as PrintManager
        val jobName = "CoW Report - ${SimpleDateFormat("yyyy-MM-dd", Locale.getDefault()).format(Date())}"
        val adapter = PdfDocumentAdapter(pdfFile)
        printManager.print(
            jobName,
            adapter,
            PrintAttributes.Builder()
                .setMediaSize(PrintAttributes.MediaSize.ISO_A4)
                .setMinMargins(PrintAttributes.Margins.NO_MARGINS)
                .build()
        )
    } catch (e: Exception) {
        e.printStackTrace()
        Toast.makeText(context, "Print failed: ${e.message}", Toast.LENGTH_LONG).show()
    }
}

class PdfDocumentAdapter(private val file: File) : PrintDocumentAdapter() {
    override fun onWrite(
        pages: Array<out android.print.PageRange>?,
        destination: android.os.ParcelFileDescriptor,
        cancellationSignal: android.os.CancellationSignal?,
        callback: WriteResultCallback
    ) {
        try {
            val input = file.inputStream()
            val output = android.os.ParcelFileDescriptor.AutoCloseOutputStream(destination)
            input.copyTo(output)
            input.close()
            output.close()
            callback.onWriteFinished(arrayOf(android.print.PageRange.ALL_PAGES))
        } catch (e: Exception) {
            callback.onWriteFailed(e.message)
        }
    }

    override fun onLayout(
        oldAttributes: PrintAttributes?,
        newAttributes: PrintAttributes,
        cancellationSignal: android.os.CancellationSignal?,
        callback: LayoutResultCallback,
        extras: android.os.Bundle?
    ) {
        if (cancellationSignal?.isCanceled == true) {
            callback.onLayoutCancelled()
            return
        }
        val info = android.print.PrintDocumentInfo.Builder("CoW_Daily_Report")
            .setContentType(android.print.PrintDocumentInfo.CONTENT_TYPE_DOCUMENT)
            .setPageCount(android.print.PrintDocumentInfo.PAGE_COUNT_UNKNOWN)
            .build()
        callback.onLayoutFinished(info, newAttributes != oldAttributes)
    }
}
